{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuperDSC",
  "description": "Schema for SuperDSC JSON objects generated by torch-spyre. Derived from SuperDSC_details.md.",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "$ref": "#/$defs/SuperDSCObject"
  },
  "$defs": {
    "DataStructDims": {
      "type": "object",
      "properties": {
        "name_": { "type": "string" },
        "in_": { "type": "integer" },
        "out_": { "type": "integer" },
        "mb_": { "type": "integer" },
        "ij_": { "type": "integer" },
        "rc_": { "type": "integer" },
        "kij_": { "type": "integer" },
        "x_": { "type": "integer" },
        "y_": { "type": "integer" },
        "sij_": { "type": "integer" },
        "zij_": { "type": "integer" },
        "i_": { "type": "integer" },
        "j_": { "type": "integer" },
        "r_": { "type": "integer" },
        "c_": { "type": "integer" },
        "ki_": { "type": "integer" },
        "kj_": { "type": "integer" },
        "si_": { "type": "integer" },
        "sj_": { "type": "integer" },
        "zi_": { "type": "integer" },
        "zj_": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "MemOrgEntry": {
      "type": "object",
      "properties": {
        "isPresent": { "type": "integer", "enum": [0, 1] },
        "isPadded": { "type": "integer", "enum": [0, 1] },
        "isZeroPadded": { "type": "integer", "enum": [0, 1] },
        "gapPerDim": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "dsOffset": { "type": "integer" }
      }
    },
    "DataTransfer": {
      "type": "object",
      "properties": {
        "srcDest": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2
        },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "isAtMainLoop": { "type": "integer", "enum": [0, 1] },
        "isAtTop": { "type": "integer", "enum": [0, 1] },
        "level": { "type": "integer" },
        "applyScale": { "type": "integer", "enum": [0, 1] },
        "parentDt": { "type": "string" },
        "auxLoopName": { "type": "string" },
        "myDsInfo": { "type": "string" },
        "coreExclude_": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "coreMap_": { "type": "array" }
      }
    },
    "CoreStateInit": {
      "type": "object",
      "properties": {
        "ebrInit_": { "type": "integer" },
        "gtr_": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "id": { "type": "integer" },
            "count": { "type": "integer" },
            "sharers": { "type": "integer" },
            "groupInfo_": { "type": "object" }
          }
        },
        "condGtr_": { "type": "array" },
        "lbrInit_": {
          "type": "array",
          "items": { "type": "integer" }
        }
      }
    },
    "LabeledDsInfo": {
      "type": "object",
      "properties": {
        "dsName_": { "type": "string" },
        "dsType_": {
          "type": "string",
          "enum": ["OUTPUT", "INPUT", "MODEL", "WEIGHT", "STACK", "HEAP", "RESERVE1", "RESERVE2", "CONST"]
        },
        "isStatic_": { "type": "integer", "enum": [0, 1] },
        "scale_": {
          "type": "array",
          "items": { "type": "number" }
        },
        "wordLength": { "type": "number" },
        "level": { "type": "integer" },
        "memOrg_": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/MemOrgEntry" }
        },
        "dataTransfers_": {
          "type": "array",
          "items": { "$ref": "#/$defs/DataTransfer" }
        },
        "hbmStartAddress_": { "type": "integer" },
        "lxStartAddress_": { "type": "integer" },
        "hbmSize_": { "type": "integer" },
        "lxSize_": { "type": "integer" },
        "lxBufferSize_": { "type": "integer" },
        "totSlicesPerDim_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "coreStateInit_": {
          "type": "array",
          "items": { "$ref": "#/$defs/CoreStateInit" }
        }
      }
    },
    "DSCEntry": {
      "description": "A single-key object where the key is the DSC name.",
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "numCoresUsed_": { "type": "integer" },
          "numCoreletsUsed_": { "type": "integer" },
          "coreIdsUsed_": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "N_": { "$ref": "#/$defs/DataStructDims" },
          "unpadN_": { "$ref": "#/$defs/DataStructDims" },
          "dscN_": { "$ref": "#/$defs/DataStructDims" },
          "ChipD_": { "$ref": "#/$defs/DataStructDims" },
          "ChipletD_": { "$ref": "#/$defs/DataStructDims" },
          "CoreD_": { "$ref": "#/$defs/DataStructDims" },
          "CoreletD_": { "$ref": "#/$defs/DataStructDims" },
          "B_": { "$ref": "#/$defs/DataStructDims" },
          "T_": { "$ref": "#/$defs/DataStructDims" },
          "Tel_": { "$ref": "#/$defs/DataStructDims" },
          "P_": { "$ref": "#/$defs/DataStructDims" },
          "Pel_": { "$ref": "#/$defs/DataStructDims" },
          "loopOrder_": {
            "type": "array",
            "items": { "type": "string" }
          },
          "loopProperties_": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "scale_": { "type": "number" }
              }
            }
          },
          "auxLoopOrder_": { "type": "object" },
          "primaryDsInfo_": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "layoutDimOrder_": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "labeledDs_": {
            "type": "array",
            "items": { "$ref": "#/$defs/LabeledDsInfo" }
          },
          "computeOp_": { "type": "object" },
          "constantInfo_": { "type": "object" }
        }
      }
    },
    "DataOpDSC": {
      "type": "object",
      "properties": {
        "dscName_": { "type": "string" },
        "coreIdsUsed_": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "dimPool_": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primaryDs_": { "type": "object" },
        "labeledDs_": {
          "type": "array",
          "items": { "$ref": "#/$defs/LabeledDsInfo" }
        },
        "opName": { "type": "string" },
        "pcfg_": { "type": "array" }
      }
    },
    "LdsShareInfoEntry": {
      "type": "object",
      "properties": {
        "dsName_": { "type": "string" },
        "sharedDscs": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "integer" }
          }
        },
        "repeatHbmLxThroImbalDim": { "type": "array" }
      }
    },
    "ScheduleEntry": {
      "type": "object",
      "properties": {
        "datadsc_idx": { "type": "integer" },
        "dldsc_idx": { "type": "integer" },
        "before_sync": { "type": "boolean" },
        "after_sync": { "type": "boolean" }
      }
    },
    "SuperDSCObject": {
      "type": "object",
      "properties": {
        "numCoresUsed_": { "type": "integer" },
        "target_": {
          "type": "string",
          "enum": ["senulator", "sentient", "senpcfg", "sentf", "host"]
        },
        "N_": { "$ref": "#/$defs/DataStructDims" },
        "unpadN_": { "$ref": "#/$defs/DataStructDims" },
        "coreIdToDsc_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "numWkSlicesPerDim_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "coreIdToWkSlice_": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          }
        },
        "ldsShareInfo_": {
          "type": "array",
          "items": { "$ref": "#/$defs/LdsShareInfoEntry" }
        },
        "dscs_": {
          "type": "array",
          "items": { "$ref": "#/$defs/DSCEntry" }
        },
        "dataOpdscs_": {
          "type": "array",
          "items": { "$ref": "#/$defs/DataOpDSC" }
        },
        "sdscFoldProps_": { "type": "array" },
        "sdscFolds_": { "type": "object" },
        "coreFoldProp_": { "type": "object" },
        "coreletFoldProp_": { "type": "object" },
        "folded_sdsc_name_": { "type": "string" },
        "fold_coord_": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "coreIdToDscSchedule": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/ScheduleEntry" }
          }
        },
        "prodConsList": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "integer" }
          }
        },
        "opFuncsUsed_": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputSymbolsAndTags_": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "symbolDefinitions_": { "type": "object" },
        "dimToSymbolMappingOpcodeCorrection_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "pcfg_": { "type": "object" }
      },
      "anyOf": [
        {
          "properties": {
            "dscs_": { "minItems": 1 }
          },
          "required": ["dscs_"]
        },
        {
          "properties": {
            "dataOpdscs_": { "minItems": 1 }
          },
          "required": ["dataOpdscs_"]
        }
      ]
    }
  }
}
