{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuperDSC",
  "description": "Schema for SuperDSC JSON objects generated by torch-spyre and consumed by deeptools/dxp. Derived from SuperDSC_details.md, Superdsc_bundle.md, and the torch-spyre codegen in compute_ops.py.",
  "type": "object",
  "minProperties": 1,
  "maxProperties": 1,
  "additionalProperties": {
    "$ref": "#/$defs/SuperDSCObject"
  },
  "$defs": {
    "DimPaddingSizes": {
      "description": "Padding metadata for a single dimension (bundle spec).",
      "type": "object",
      "properties": {
        "frontPadding": { "type": "integer" },
        "backPadding": { "type": "integer" },
        "stride": { "type": "integer" },
        "kernelDim": { "type": "integer" }
      }
    },
    "SymbolicDimInfo": {
      "description": "Symbolic dimension constraints (bundle spec).",
      "type": "object",
      "properties": {
        "max_value": { "type": "integer" },
        "maxValue": { "type": "integer" },
        "granularity": { "type": "integer" }
      }
    },
    "DataStructDims": {
      "description": "Dimension descriptor used for N_, unpadN_, dscN_, CoreD_, ss_, el_, etc.",
      "type": "object",
      "properties": {
        "name_": { "type": "string" },
        "in_": { "type": "integer" },
        "out_": { "type": "integer" },
        "mb_": { "type": "integer" },
        "ij_": { "type": "integer" },
        "rc_": { "type": "integer" },
        "kij_": { "type": "integer" },
        "x_": { "type": "integer" },
        "y_": { "type": "integer" },
        "sij_": { "type": "integer" },
        "zij_": { "type": "integer" },
        "i_": { "type": "integer" },
        "j_": { "type": "integer" },
        "r_": { "type": "integer" },
        "c_": { "type": "integer" },
        "ki_": { "type": "integer" },
        "kj_": { "type": "integer" },
        "si_": { "type": "integer" },
        "sj_": { "type": "integer" },
        "zi_": { "type": "integer" },
        "zj_": { "type": "integer" },
        "paddingSizes_": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/DimPaddingSizes" }
        },
        "symbolicDimInfo_": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/SymbolicDimInfo" }
        }
      }
    },
    "MemOrgEntry": {
      "type": "object",
      "properties": {
        "isPresent": { "type": "integer", "enum": [0, 1] },
        "isPadded": { "type": "integer", "enum": [0, 1] },
        "isZeroPadded": { "type": "integer", "enum": [0, 1] },
        "gapPerDim": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "dsOffset": { "type": "integer" }
      }
    },
    "DataTransfer": {
      "type": "object",
      "properties": {
        "srcDest": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "maxItems": 2
        },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "isAtMainLoop": { "type": "integer", "enum": [0, 1] },
        "isAtTop": { "type": "integer", "enum": [0, 1] },
        "level": { "type": "integer" },
        "applyScale": { "type": "integer", "enum": [0, 1] },
        "parentDt": { "type": "string" },
        "auxLoopName": { "type": "string" },
        "myDsInfo": { "type": "string" },
        "coreExclude_": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "coreMap_": { "type": "array" }
      }
    },
    "CoreStateInit": {
      "type": "object",
      "properties": {
        "ebrInit_": { "type": "integer" },
        "gtr_": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "id": { "type": "integer" },
            "count": { "type": "integer" },
            "sharers": { "type": "integer" },
            "groupInfo_": { "type": "object" }
          }
        },
        "condGtr_": { "type": "array" },
        "lbrInit_": {
          "type": "array",
          "items": { "type": "integer" }
        }
      }
    },
    "FoldDimProp": {
      "description": "Fold dimension property. torch-spyre codegen uses factor_/label_ keys.",
      "type": "object",
      "properties": {
        "factor_": { "type": "integer" },
        "label_": { "type": "string" }
      }
    },
    "FoldManager": {
      "description": "FoldManager structure used in sdscFolds_, startAddressCoreCorelet_, and constantInfo_.data_.",
      "type": "object",
      "properties": {
        "dim_prop_func": {
          "type": "array",
          "items": { "type": "object" }
        },
        "dim_prop_attr": {
          "type": "array",
          "items": { "$ref": "#/$defs/FoldDimProp" }
        },
        "data_": { "type": "object" }
      }
    },
    "CoordInfoValue": {
      "description": "Coordinate info value for a single dimension in scheduleTree_ coordinates.",
      "type": "object",
      "properties": {
        "spatial": { "type": "integer" },
        "temporal": { "type": "integer" },
        "elemArr": { "type": "integer" },
        "padding": { "type": "string" },
        "folds": { "$ref": "#/$defs/FoldManager" }
      }
    },
    "AllocateNode": {
      "description": "Schedule tree entry for memory allocation. Covers fields from both torch-spyre codegen and deeptools bundle spec.",
      "type": "object",
      "properties": {
        "nodeType_": { "type": "string" },
        "name_": { "type": "string" },
        "prev_": { "type": "string" },
        "ldsIdx_": { "type": "integer" },
        "component_": { "type": "string" },
        "layoutDimOrder_": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxDimSizes_": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "startAddressCoreCorelet_": { "$ref": "#/$defs/FoldManager" },
        "isStartAddrSymbolic_": { "type": "boolean" },
        "coordinates_": {
          "description": "Coordinate info as generated by torch-spyre codegen.",
          "type": "object",
          "properties": {
            "coordInfo": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/CoordInfoValue" }
            },
            "coreIdToWkSlice_": { "type": "object" }
          }
        },
        "allocateCoordinates_": {
          "description": "Coordinate folds as expected by deeptools bundle spec.",
          "type": "array",
          "items": { "$ref": "#/$defs/CoordinateFold" }
        },
        "indirectAllocType_": { "type": "string" },
        "relatedIndirectAccessAlloc_": { "type": "string" }
      }
    },
    "CoordinateFold": {
      "description": "Affine fold expression for coordinate arrangement (bundle spec).",
      "type": "object",
      "properties": {
        "alpha": { "type": "integer" },
        "beta": { "type": "integer" },
        "factor": { "type": "integer" }
      }
    },
    "VariableSymbol": {
      "description": "Symbolic variable reference linking a dimension to a runtime symbol.",
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "tag": { "type": "string" }
      }
    },
    "ComputeOpAttributes": {
      "description": "Attributes of a compute operation.",
      "type": "object",
      "properties": {
        "dataFormat_": { "type": "string" },
        "fidelity_": { "type": "string" }
      }
    },
    "ComputeOp": {
      "description": "A compute operation specification within a DSC.",
      "type": "object",
      "properties": {
        "exUnit": { "type": "string" },
        "opFuncName": { "type": "string" },
        "attributes_": { "$ref": "#/$defs/ComputeOpAttributes" },
        "location": { "type": "string" },
        "inputLabeledDs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputLabeledDs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "indirectAccessIndexLabeledDs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ConstantInfo": {
      "description": "A constant value entry within constantInfo_.",
      "type": "object",
      "properties": {
        "name_": { "type": "string" },
        "dataFormat_": { "type": "string" },
        "data_": { "$ref": "#/$defs/FoldManager" }
      }
    },
    "DataStage": {
      "description": "Per-core dimension sizes (bundle spec: dataStageParam_).",
      "type": "object",
      "properties": {
        "name_": { "type": "string" },
        "ss_": { "$ref": "#/$defs/DataStructDims" },
        "el_": { "$ref": "#/$defs/DataStructDims" }
      }
    },
    "LabeledDsInfo": {
      "type": "object",
      "properties": {
        "ldsIdx_": { "type": "integer" },
        "dsName_": { "type": "string" },
        "dsType_": {
          "type": "string",
          "enum": ["OUTPUT", "INPUT", "MODEL", "WEIGHT", "STACK", "HEAP", "RESERVE1", "RESERVE2", "CONST", "KERNEL", "KERNEL_IDX"]
        },
        "isStatic_": { "type": "integer", "enum": [0, 1] },
        "scale_": {
          "type": "array",
          "items": { "type": "number" }
        },
        "wordLength": { "type": "number" },
        "dataFormat_": { "type": "string" },
        "level": { "type": "integer" },
        "memOrg_": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/MemOrgEntry" }
        },
        "dataTransfers_": {
          "type": "array",
          "items": { "$ref": "#/$defs/DataTransfer" }
        },
        "hbmStartAddress_": { "type": "integer" },
        "lxStartAddress_": { "type": "integer" },
        "hbmSize_": { "type": "integer" },
        "lxSize_": { "type": "integer" },
        "lxBufferSize_": { "type": "integer" },
        "totSlicesPerDim_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "coreStateInit_": {
          "type": "array",
          "items": { "$ref": "#/$defs/CoreStateInit" }
        }
      }
    },
    "DSCEntry": {
      "description": "A single-key object where the key is the DSC name.",
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "numCoresUsed_": { "type": "integer" },
          "numCoreletsUsed_": { "type": "integer" },
          "coreIdsUsed_": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "N_": { "$ref": "#/$defs/DataStructDims" },
          "unpadN_": { "$ref": "#/$defs/DataStructDims" },
          "dscN_": { "$ref": "#/$defs/DataStructDims" },
          "ChipD_": { "$ref": "#/$defs/DataStructDims" },
          "ChipletD_": { "$ref": "#/$defs/DataStructDims" },
          "CoreD_": { "$ref": "#/$defs/DataStructDims" },
          "CoreletD_": { "$ref": "#/$defs/DataStructDims" },
          "B_": { "$ref": "#/$defs/DataStructDims" },
          "T_": { "$ref": "#/$defs/DataStructDims" },
          "Tel_": { "$ref": "#/$defs/DataStructDims" },
          "P_": { "$ref": "#/$defs/DataStructDims" },
          "Pel_": { "$ref": "#/$defs/DataStructDims" },
          "coordinateMasking_": { "type": "object" },
          "maskingConstId_": { "type": "integer" },
          "dataStageParam_": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/DataStage" }
          },
          "primaryDsInfo_": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "layoutDimOrder_": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "stickDimOrder_": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "stickSize_": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              }
            }
          },
          "scheduleTree_": {
            "type": "array",
            "items": { "$ref": "#/$defs/AllocateNode" }
          },
          "labeledDs_": {
            "type": "array",
            "items": { "$ref": "#/$defs/LabeledDsInfo" },
            "maxItems": 8
          },
          "loopOrder_": {
            "type": "array",
            "items": { "type": "string" }
          },
          "loopProperties_": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "scale_": { "type": "number" }
              }
            }
          },
          "auxLoopOrder_": { "type": "object" },
          "computeOp_": {
            "type": "array",
            "items": { "$ref": "#/$defs/ComputeOp" }
          },
          "constantInfo_": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": { "$ref": "#/$defs/ConstantInfo" }
              }
            ]
          },
          "dimToSymbolMapping_": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "$ref": "#/$defs/VariableSymbol" }
            }
          }
        }
      }
    },
    "DataOpDSC": {
      "type": "object",
      "properties": {
        "dscName_": { "type": "string" },
        "coreIdsUsed_": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "dimPool_": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primaryDs_": { "type": "object" },
        "labeledDs_": {
          "type": "array",
          "items": { "$ref": "#/$defs/LabeledDsInfo" },
          "maxItems": 8
        },
        "opName": { "type": "string" },
        "pcfg_": { "type": "array" }
      }
    },
    "LdsShareInfoEntry": {
      "type": "object",
      "properties": {
        "dsName_": { "type": "string" },
        "sharedDscs": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "integer" }
          }
        },
        "repeatHbmLxThroImbalDim": { "type": "array" }
      }
    },
    "ScheduleEntry": {
      "description": "Schedule entry for coreIdToDscSchedule. Accepts both array format (codegen) and object format (deeptools).",
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 4,
          "maxItems": 4
        },
        {
          "type": "object",
          "properties": {
            "datadsc_idx": { "type": "integer" },
            "dldsc_idx": { "type": "integer" },
            "before_sync": { "type": "boolean" },
            "after_sync": { "type": "boolean" }
          }
        }
      ]
    },
    "SuperDSCObject": {
      "type": "object",
      "properties": {
        "numCoresUsed_": { "type": "integer" },
        "target_": {
          "type": "string",
          "enum": ["senulator", "sentient", "senpcfg", "sentf", "host"]
        },
        "N_": { "$ref": "#/$defs/DataStructDims" },
        "unpadN_": { "$ref": "#/$defs/DataStructDims" },
        "coreIdToDsc_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "numWkSlicesPerDim_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "coreIdToWkSlice_": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          }
        },
        "ldsShareInfo_": {
          "type": "array",
          "items": { "$ref": "#/$defs/LdsShareInfoEntry" }
        },
        "dscs_": {
          "type": "array",
          "items": { "$ref": "#/$defs/DSCEntry" },
          "maxItems": 1
        },
        "dataOpdscs_": {
          "type": "array",
          "items": { "$ref": "#/$defs/DataOpDSC" }
        },
        "sdscFoldProps_": {
          "type": "array",
          "items": { "$ref": "#/$defs/FoldDimProp" }
        },
        "sdscFolds_": { "$ref": "#/$defs/FoldManager" },
        "coreFoldProp_": { "$ref": "#/$defs/FoldDimProp" },
        "coreletFoldProp_": { "$ref": "#/$defs/FoldDimProp" },
        "folded_sdsc_name_": { "type": "string" },
        "fold_coord_": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "coreIdToDscSchedule": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/ScheduleEntry" }
          }
        },
        "prodConsList": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "integer" }
          }
        },
        "opFuncsUsed_": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputSymbolsAndTags_": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "symbolDefinitions_": { "type": "object" },
        "dimToSymbolMappingOpcodeCorrection_": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "pcfg_": { "type": "object" },
        "spb_": {
          "type": "array",
          "maxItems": 1
        }
      },
      "anyOf": [
        {
          "properties": {
            "dscs_": { "minItems": 1 }
          },
          "required": ["dscs_"]
        },
        {
          "properties": {
            "dataOpdscs_": { "minItems": 1 }
          },
          "required": ["dataOpdscs_"]
        }
      ]
    }
  }
}
